PORT=3000
NODE_ENV=development

# MongoDB Atlas (or local: mongodb://localhost:27017/iot_ac)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/iot_ac

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MQTT
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=backend
MQTT_PASSWORD=securebackendpass
MQTT_CLIENT_ID=iot-ac-backend

# Socket.IO CORS origin
CORS_ORIGIN=*

# Unstable device threshold (minutes without telemetry)
UNSTABLE_THRESHOLD_MINUTES=5
